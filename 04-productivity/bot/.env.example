# Productivity Stack Environment Variables Template
# Copy this to .env and fill in your values

# Telegram Bot Token (REQUIRED)
# Get from: https://t.me/BotFather
# 1. Start chat with @BotFather
# 2. Send: /newbot
# 3. Follow instructions
# 4. Copy the token here
TELEGRAM_BOT_TOKEN=

# Bot Admin User ID (OPTIONAL)
# Get from: @userinfobot
# Send /start to @userinfobot to get your Telegram user ID
BOT_ADMIN_USER_ID=

# Memos Configuration
MEMOS_URL=http://memos:5230

# Bot Scheduling Settings (OPTIONAL)
# Time for daily summary (24-hour format)
DAILY_SUMMARY_TIME=20:00

# Day of week for weekly summary (0=Sunday, 1=Monday, etc.)
WEEKLY_SUMMARY_DAY=0

# Timezone
TZ=Europe/London
